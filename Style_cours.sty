% ==============================================================================
% X. STYLE DES TABLEAUX
% ==============================================================================

% Tableau avec en-tête coloré et lignes alternées
\newcommand{\tableauHeader}[1]{%
    \rowcolor{TableauEntete}\color{white}\bfseries #1
}

\newcommand{\ligneTableau}[1]{%
    \rowcolor{TableauPair} #1
}

% Commande de tableau standard du cours
\newenvironment{tableaucours}[2]{%
    \begin{table}[htbp]
    \centering
    \small
    \rowcolors{2}{TableauPair}{TableauImpair}
    \begin{tabular}{#1}
    \toprule
    #2
    \midrule
}{%
    \bottomrule
    \end{tabular}
    \end{table}
}


